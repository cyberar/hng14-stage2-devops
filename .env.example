# ==========================================
# Infrastructure Images
# ==========================================
REDIS_IMAGE=redis:7-alpine
API_BUILD_CONTEXT=./api
WORKER_BUILD_CONTEXT=./worker
FRONTEND_BUILD_CONTEXT=./frontend

# ==========================================
# Internal Docker Networking
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=changeme

# ==========================================
# Port Mappings (Host : Container)
# ==========================================
API_HOST_PORT=8000
API_CONTAINER_PORT=8000
FRONTEND_HOST_PORT=80
FRONTEND_CONTAINER_PORT=8080

# ==========================================
# CPU & Memory Limits (Adjust to your server)
# ==========================================
REDIS_CPU_LIMIT=0.25
REDIS_MEM_LIMIT=128M
REDIS_CPU_RESERVE=0.25
REDIS_MEM_RESERVE=64M

API_CPU_LIMIT=0.50
API_MEM_LIMIT=256M
API_CPU_RESERVE=0.25
API_MEM_RESERVE=128M

WORKER_CPU_LIMIT=1.0
WORKER_MEM_LIMIT=512M
WORKER_CPU_RESERVE=0.25
WORKER_MEM_RESERVE=256M

FRONTEND_CPU_LIMIT=0.25
FRONTEND_MEM_LIMIT=64M
FRONTEND_CPU_RESERVE=0.25
FRONTEND_MEM_RESERVE=32M